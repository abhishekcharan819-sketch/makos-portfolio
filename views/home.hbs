<!-- Full screen background -->
<div class="home-bg">
  <img
    src="https://framerusercontent.com/images/kDcQjTOqVphBNghgFUi9K754s.jpg"
    alt="Background portrait"
    class="bg-portrait"
  />
  <!-- Grain overlay -->
  <div class="grain"></div>

  <!-- Floating project thumbnails -->
  <div class="floating-projects" id="floatingProjects"></div>

  <!-- macOS Dock -->
  <div class="dock">
    <div class="dock-inner">
      <!-- Profile -->
      <a href="/" class="dock-item" data-tooltip="Portfolio">
        <img src="https://framerusercontent.com/images/kDcQjTOqVphBNghgFUi9K754s.jpg" alt="Profile" class="dock-icon dock-icon-round" />
      </a>
      <!-- Notes -->
      <a href="#" class="dock-item" data-tooltip="Notes">
        <img src="https://framerusercontent.com/images/4ar8CL6aUtjymV8jTsXrcPzXCM.svg" alt="Notes" class="dock-icon" />
      </a>

      <!-- Divider -->
      <div class="dock-divider"></div>

      <!-- Instagram -->
      <a href="https://www.instagram.com/" target="_blank" rel="noopener" class="dock-item" data-tooltip="Instagram">
        <img src="https://framerusercontent.com/images/Q0Z0p8LOZhN2hJ2arLjEtkqQD0.png" alt="Instagram" class="dock-icon" />
      </a>
      <!-- X -->
      <a href="https://www.x.com/" target="_blank" rel="noopener" class="dock-item" data-tooltip="X">
        <img src="https://framerusercontent.com/images/vjmmhizcqEgw5ZT5SNFQMpxD00.png" alt="X" class="dock-icon" />
      </a>
      <!-- Behance -->
      <a href="https://www.behance.com/" target="_blank" rel="noopener" class="dock-item" data-tooltip="Behance">
        <img src="https://framerusercontent.com/images/edJkRGfjqjPajyxmEgsUCKVgjE.png" alt="Behance" class="dock-icon" />
      </a>
    </div>
  </div>
</div>

<script>
  // Inject projects from server
  window.PROJECTS = {{{projects}}};
</script>
