<!-- macOS-style window chrome -->
<div class="macos-window">

  <!-- Top bar / title bar -->
  <div class="titlebar">
    <div class="titlebar-dots">
      <span class="dot dot-red"></span>
      <span class="dot dot-yellow"></span>
      <span class="dot dot-green"></span>
    </div>
    <div class="titlebar-title">Portfolio — Finder</div>
    <div class="titlebar-controls">
      <button class="ctrl-btn" aria-label="Search">
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="6" cy="6" r="4.5" stroke="currentColor" stroke-width="1.3"/><path d="M9.5 9.5L12 12" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
      </button>
    </div>
  </div>

  <!-- Sidebar + Main content layout -->
  <div class="window-body">

    <!-- Sidebar -->
    <aside class="sidebar">

      <!-- Profile card -->
      <div class="sidebar-profile">
        <div class="profile-avatar-wrap">
          <img
            src="https://framerusercontent.com/images/kDcQjTOqVphBNghgFUi9K754s.jpg?width=1024&height=1024"
            alt="Profile"
            class="profile-avatar"
          />
        </div>
        <div class="profile-info">
          <div class="profile-label">About Me</div>
          <div class="profile-badge">
            <img src="https://framerusercontent.com/images/4ar8CL6aUtjymV8jTsXrcPzXCM.svg?width=120&height=120" alt="Badge" class="profile-badge-img" />
          </div>
        </div>
      </div>

      <!-- Sidebar nav -->
      <nav class="sidebar-nav">
        <div class="nav-section-label">Pages</div>
        <a href="/" class="nav-item active">
          <svg class="nav-icon" viewBox="0 0 16 16" fill="none"><rect x="1.5" y="1.5" width="5" height="5" rx="1" fill="currentColor"/><rect x="9.5" y="1.5" width="5" height="5" rx="1" fill="currentColor" opacity=".5"/><rect x="1.5" y="9.5" width="5" height="5" rx="1" fill="currentColor" opacity=".5"/><rect x="9.5" y="9.5" width="5" height="5" rx="1" fill="currentColor" opacity=".3"/></svg>
          Home
        </a>
        <a href="#works" class="nav-item">
          <svg class="nav-icon" viewBox="0 0 16 16" fill="none"><path d="M2 4h12M2 8h8M2 12h10" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
          Works
        </a>
        <a href="#about" class="nav-item">
          <svg class="nav-icon" viewBox="0 0 16 16" fill="none"><circle cx="8" cy="5.5" r="2.5" stroke="currentColor" stroke-width="1.3"/><path d="M2.5 13c0-3.038 2.462-5.5 5.5-5.5s5.5 2.462 5.5 5.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/></svg>
          About
        </a>
      </nav>

      <div class="sidebar-divider"></div>

      <!-- Social links -->
      <div class="nav-section-label">Socials</div>
      <div class="sidebar-socials">
        <a href="https://www.instagram.com/" target="_blank" rel="noopener" class="social-link">
          <img src="https://framerusercontent.com/images/Q0Z0p8LOZhN2hJ2arLjEtkqQD0.png?width=1455&height=1455" alt="Instagram" class="social-icon" />
          <span>Instagram</span>
        </a>
        <a href="https://www.x.com/" target="_blank" rel="noopener" class="social-link">
          <img src="https://framerusercontent.com/images/vjmmhizcqEgw5ZT5SNFQMpxD00.png?width=1600&height=1600" alt="X" class="social-icon" />
          <span>X</span>
        </a>
        <a href="https://www.behance.com/" target="_blank" rel="noopener" class="social-link">
          <img src="https://framerusercontent.com/images/edJkRGfjqjPajyxmEgsUCKVgjE.png?width=1024&height=1024" alt="Behance" class="social-icon" />
          <span>Behance</span>
        </a>
      </div>

      <!-- Notes widget -->
      <div class="sidebar-divider"></div>
      <div class="sidebar-notes">
        <div class="notes-header">
          <svg class="notes-icon" viewBox="0 0 16 16" fill="none"><rect x="2" y="2" width="12" height="12" rx="2" stroke="currentColor" stroke-width="1.3"/><path d="M5 5.5h6M5 8h4M5 10.5h5" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
          Notes
        </div>
        <p class="notes-text">Open to new collaborations &amp; commissions. Let's create something together.</p>
      </div>

    </aside>

    <!-- Main content pane -->
    <section class="main-pane">

      <!-- Marquee strip -->
      <div class="marquee-wrap">
        <div class="marquee-track">
          <span>Photographer</span>
          <span class="dot-sep">·</span>
          <span>Visual Artist</span>
          <span class="dot-sep">·</span>
          <span>Creative Director</span>
          <span class="dot-sep">·</span>
          <span>Film Maker</span>
          <span class="dot-sep">·</span>
          <span>Photographer</span>
          <span class="dot-sep">·</span>
          <span>Visual Artist</span>
          <span class="dot-sep">·</span>
          <span>Creative Director</span>
          <span class="dot-sep">·</span>
          <span>Film Maker</span>
          <span class="dot-sep">·</span>
          <span>Photographer</span>
          <span class="dot-sep">·</span>
          <span>Visual Artist</span>
          <span class="dot-sep">·</span>
          <span>Creative Director</span>
          <span class="dot-sep">·</span>
          <span>Film Maker</span>
          <span class="dot-sep">·</span>
        </div>
      </div>

      <!-- Works grid -->
      <div class="works-section" id="works">
        <div class="works-header">
          <h2 class="works-title">Works</h2>
          <span class="works-count">{{projects.length}}</span>
        </div>

        <!-- Horizontal scroll carousel (top) -->
        <div class="works-carousel">
          {{#each projects}}
          <div class="carousel-item">
            <img src="{{this.image}}" alt="{{this.title}}" class="carousel-img" loading="lazy" />
            <div class="carousel-caption">{{this.title}}</div>
          </div>
          {{/each}}
        </div>

        <!-- Works grid list -->
        <div class="works-grid">
          {{#each projects}}
          <a href="/works/{{this.slug}}" class="work-card">
            <div class="work-card-img-wrap">
              <img src="{{this.thumb}}" alt="{{this.title}}" class="work-card-img" loading="lazy" />
            </div>
            <div class="work-card-info">
              <span class="work-card-title">{{this.title}}</span>
              <svg class="work-card-arrow" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
          </a>
          {{/each}}
        </div>
      </div>

    </section>
  </div>
</div>
