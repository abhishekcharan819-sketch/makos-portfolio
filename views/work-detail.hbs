<!-- Full screen background using project image -->
<div class="detail-bg">
  <img src="{{project.image}}" alt="{{project.title}}" class="bg-portrait bg-portrait-blur" />
  <div class="grain"></div>

  <!-- Floating macOS window -->
  <div class="detail-window" id="detailWindow">
    <!-- Titlebar -->
    <div class="titlebar">
      <div class="titlebar-dots">
        <a href="/" class="dot dot-red" title="Close"></a>
        <span class="dot dot-yellow"></span>
        <span class="dot dot-green"></span>
      </div>
      <div class="titlebar-title">{{project.title}}</div>
      <div style="width:52px"></div>
    </div>

    <!-- Window content -->
    <div class="window-content">
      <h1 class="project-title">{{project.title}}</h1>
      <p class="project-desc">{{project.description}}</p>

      <div class="project-meta">
        <div class="meta-item">
          <span class="meta-label">Client</span>
          <span class="meta-value">{{project.client}}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Year</span>
          <span class="meta-value">{{project.year}}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Project type</span>
          <span class="meta-value">{{project.projectType}}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Credits</span>
          <span class="meta-value">{{project.credits}}</span>
        </div>
      </div>

      <!-- Project image inside window -->
      <div class="window-img-wrap">
        <img src="{{project.image}}" alt="{{project.title}}" class="window-img" />
      </div>
    </div>
  </div>

  <!-- macOS Dock -->
  <div class="dock">
    <div class="dock-inner">
      <a href="/" class="dock-item" data-tooltip="Portfolio">
        <img src="https://framerusercontent.com/images/kDcQjTOqVphBNghgFUi9K754s.jpg" alt="Profile" class="dock-icon dock-icon-round" />
      </a>
      <a href="#" class="dock-item" data-tooltip="Notes">
        <img src="https://framerusercontent.com/images/4ar8CL6aUtjymV8jTsXrcPzXCM.svg" alt="Notes" class="dock-icon" />
      </a>
      <div class="dock-divider"></div>
      <a href="https://www.instagram.com/" target="_blank" rel="noopener" class="dock-item" data-tooltip="Instagram">
        <img src="https://framerusercontent.com/images/Q0Z0p8LOZhN2hJ2arLjEtkqQD0.png" alt="Instagram" class="dock-icon" />
      </a>
      <a href="https://www.x.com/" target="_blank" rel="noopener" class="dock-item" data-tooltip="X">
        <img src="https://framerusercontent.com/images/vjmmhizcqEgw5ZT5SNFQMpxD00.png" alt="X" class="dock-icon" />
      </a>
      <a href="https://www.behance.com/" target="_blank" rel="noopener" class="dock-item" data-tooltip="Behance">
        <img src="https://framerusercontent.com/images/edJkRGfjqjPajyxmEgsUCKVgjE.png" alt="Behance" class="dock-icon" />
      </a>
    </div>
  </div>
</div>
